{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Spindle",
	"version": "0.2.0",
	"identifier": "ca.liminalhq.spindle",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "Spindle",
				"width": 1280,
				"height": 800,
				"minWidth": 960,
				"minHeight": 640,
				"decorations": false
			}
		],
		"security": {
			"csp": null,
			"assetProtocol": {
				"scope": ["$APPCACHE/**", "$APPDATA/**", "$HOME/**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"linux": {
			"deb": {
				"depends": ["ffmpeg"]
			},
			"rpm": {
				"recommends": ["(ffmpeg or ffmpeg-free)"]
			}
		},
		"category": "Video",
		"publisher": "Liminal HQ",
		"shortDescription": "A desktop optical-disc authoring workstation for DVD projects.",
		"longDescription": "Spindle is a desktop optical-disc authoring workstation built with Tauri, Rust, and React. It helps plan DVD projects, inspect source assets, design menus, and compile native authoring output with bundled sidecar tooling.",
		"copyright": "Copyright 2026 Liminal HQ, Scott Morris",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"externalBin": [
			"binaries/spindle-dvdauthor",
			"binaries/spindle-spumux",
			"binaries/spindle-genisoimage",
			"binaries/spindle-mkisofs"
		]
	}
}
