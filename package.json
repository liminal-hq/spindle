{
	"name": "@liminal-hq/spindle-workspace",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": "24.14.0",
		"pnpm": "10.32.1"
	},
	"scripts": {
		"build": "pnpm --filter @liminal-hq/spindle build",
